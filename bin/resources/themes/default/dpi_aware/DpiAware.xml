<?xml version="1.0" encoding="UTF-8"?>
<Window size="900,640" min_size="80,50" use_system_caption="false" snap_layout_menu="true" sys_menu="true" sys_menu_rect="0,0,36,36" caption="0,0,0,36" shadow_attached="true" layered_window="true" alpha="255" size_box="4,4,4,4">
    <VBox bkcolor="bg_window_light" visible="true">    
        <!-- 标题栏区域 -->
        <HBox name="window_title_bar" width="stretch" height="36" bkcolor="bg_titlebar">
            <Label name="title" width="100%" height="100%" mouse_enabled="false" text_padding="10,0,0,0" text_align="vcenter"/>
            <Button class="btn_switch_theme" height="32" width="40" name="btn_window_theme" margin="0,2,0,2"/>
            <Button class="btn_switch_lang" height="32" width="40" name="btn_window_language" margin="0,2,0,2"/>
            <Button class="btn_wnd_fullscreen_11" height="32" width="40" name="btn_window_fullscreen" margin="0,2,0,2"/>
            <Button class="btn_wnd_min_11" height="32" width="40" name="btn_window_min" margin="0,2,0,2"/>
            <Box height="stretch" width="40" margin="0,2,0,2">
                <Button class="btn_wnd_max_11" height="32" width="stretch" name="btn_window_max"/>
                <Button class="btn_wnd_restore_11" height="32" width="stretch" name="btn_window_restore" visible="false"/>
            </Box>
            <Button class="btn_wnd_close_11" height="stretch" width="40" name="btn_window_close" margin="0,0,0,2"/>
        </HBox>
        
        <!-- 工作区域，除了标题栏外的内容都放在这个大的Box区域 -->
        <Box>
            <GroupVBox name="group_box_test" halign="center" valign="center" width="640" height="auto">
                <HBox height="40" width="100%" valign="center" child_halign="center">
                    <Label text_id="STRID_DPIAWARE_TITLE" height="40" width="auto" text_align="right,vcenter"/>
                    <Label name="group_box_pos" text="[left: 0, top: 0]" height="40" width="auto" text_align="left,vcenter"/>
                </HBox>
                <HBox height="auto" width="100%" valign="center" padding="20,0,0,0">
                    <Label text_id="STRID_DPIAWARE_CURRENT_AWARENESS" width="auto" text_align="left,vcenter"/>
                    <Label name="dpi_awareness" text="PROCESS_DPI_UNAWARE" width="100%" text_align="left,vcenter"/>
                </HBox>
                <HBox height="auto" width="100%" valign="center" padding="20,0,0,0">
                    <Label text_id="STRID_DPIAWARE_CURRENT_DPI_SCALE" width="auto" text_align="left,vcenter"/>
                    <Label name="primary_monitor_display_scale" text="200%" width="100%" text_align="left,vcenter"/>
                </HBox>
                <HBox height="auto" width="100%" valign="center" padding="20,0,0,0">
                    <Label text_id="STRID_DPIAWARE_WINDOW_DISPLAY_SCALE" width="auto" text_align="left,vcenter"/>
                    <Label name="window_display_scale" text="200%" width="100%" text_align="left,vcenter"/>
                </HBox>
                <VBox height="auto" width="100%" valign="center" padding="20,0,0,0">
                    <HBox height="auto">
                        <Label text_id="STRID_DPIAWARE_WINDOW_SIZE" width="auto" text_align="left,vcenter"/>
                        <Label name="window_size" text="L:0,T:0,W:0,H:0" width="auto" text_align="left,vcenter"/>
                    </HBox>
                    <HBox height="auto">
                        <Label text_id="STRID_DPIAWARE_WINDOW_CLIENT_SIZE" width="auto" text_align="left,vcenter"/>
                        <Label name="window_client_size" text="L:0,T:0,W:0,H:0" width="auto" text_align="left,vcenter"/>
                    </HBox>
                </VBox>
                <VBox name="SDL" height="auto" visible="true" width="100%" valign="center" padding="20,0,0,0" margin="0,4,0,0">
                    <HBox height="auto" >
                        <Label text="SDL_GetWindowSize：" width="300" text_align="right,vcenter"/>
                        <Label name="SDL_GetWindowSize" text="W:0,H:0" width="auto" text_align="left,vcenter"/>
                    </HBox>
                    <HBox height="auto" >
                        <Label text="SDL_GetWindowSizeInPixels：" width="300" text_align="right,vcenter"/>
                        <Label name="SDL_GetWindowSizeInPixels" text="W:0,H:0" width="auto" text_align="left,vcenter"/>
                    </HBox>
                    <HBox height="auto" >
                        <Label text="SDL_GetDisplayContentScale：" width="300" text_align="right,vcenter"/>
                        <Label name="SDL_GetDisplayContentScale" text="0" width="auto" text_align="left,vcenter"/>
                    </HBox>
                    <HBox height="auto" >
                        <Label text="SDL_GetWindowDisplayScale：" width="300" text_align="right,vcenter"/>
                        <Label name="SDL_GetWindowDisplayScale" text="0" width="auto" text_align="left,vcenter"/>
                    </HBox>
                    <HBox height="auto" >
                        <Label text="SDL_GetWindowPixelDensity：" width="300" text_align="right,vcenter"/>
                        <Label name="SDL_GetWindowPixelDensity" text="0" width="auto" text_align="left,vcenter"/>
                    </HBox>
                </VBox>
                <HBox height="auto" width="100%" valign="center" margin="0,8,0,8">
                    <RichText class="rich_text" bkcolor="green" row_spacing_mul="1.5" width="100%" height="auto" margin="4,0,4,0" text_id="STRID_DPIAWARE_RICHTEXT"/>
                </HBox>
                <HBox height="auto">
                    <VBox height="auto">
                        <HBox valign="center" height="auto">
                            <Label text_id="STRID_DPIAWARE_MODIFY_DPI" height="32" valign="center" text_align="left,vcenter" margin="4,0,0,0"/>
                            <RichEdit class="simple simple_border" name="display_scale_factor" text="" number="true" height="32" width="60" max_char="4" min_number="0" max_number="500" valign="center" text_align="hcenter,vcenter" margin="1,0,4,0"/>
                            <Button class="btn_global_blue_80x30" height="32" width="auto" valign="center" name="set_display_scale_factor" text_id="STRID_DPIAWARE_MODIFY_DPI_BTN" text_padding="10,0,10,0" />
                        </HBox>
                        <HBox height="40" valign="center" halign="center" margin="160,40,1,1" child_halign="left">
                            <Button class="btn_global_blue_80x30" width="auto" name="NewWindow" text_id="STRID_DPIAWARE_NEW_WINDOW" text_padding="10,0,10,0" />
                        </HBox>
                    </VBox>
                    <VBox border_size="1" border_color="blue" width="auto" height="auto" margin="4,4,4,4">
                        <Control bkimage="autumn.png" width="auto" height="auto" halign="center" valign="center" margin="2,2,2,2" border_size="1" border_color="red"/>
                    </VBox>
                </HBox>
            </GroupVBox>
        </Box>
    </VBox>
</Window>
