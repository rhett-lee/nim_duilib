<?xml version="1.0" encoding="UTF-8"?>
<Window size="800,600" min_size="300,200" caption="0,0,0,36" size_box="4,4,4,4" text_id="STRID_CEF_BROWSER_MULTI_TAB" shadow_attached="true" layered_window="true" icon="public/caption/logo.ico">
    <!--新建标签按钮：纯色按钮-->
    <Class name="tab_item_new_add_btn" font="system_regular_18" text_align="hcenter,vcenter" valign="center"
                                       normal_text_color="text_default"
                                       disabled_text_color="text_disabled"
                                       normal_color=""
                                       hot_color="bg_tab_ctrl_item_close_hover"
                                       pushed_color="bg_tab_ctrl_item_close_pressed"/>
    <Class name="tab_ctrl_left_line" bkcolor="border_tab_ctrl_item" width="1" height="22" halign="center" valign="center" mouse_enabled="false"/>

    <Class name="btn_cef_browser" text_align="hcenter,vcenter"
                                  normal_text_color="text_btn_normal" disabled_text_color="text_btn_disabled"
                                  normal_color="" hot_color="bg_btn_hover"
                                  pushed_color="bg_btn_pressed" disabled_color=""
                                  border_size="${border_btn_size}"
                                  normal_border_color="" hot_border_color="border_btn_hover"
                                  pushed_border_color="border_btn_pressed" disabled_border_color=""/>

    <VBox bkcolor="bg_tab_ctrl_item_selected">
        <HBox name="title_bar" width="stretch" height="36" bkcolor="bg_titlebar">
            <!-- 图标区域 -->
            <Control width="36" height="36" bkimage="file='public/caption/logo.ico' width='22' height='22' halign='center' valign='center'"/>

            <!-- 竖线区域 -->
            <Control class="tab_ctrl_left_line" padding="0,6,0,6" margin="0,0,2,0"/>

            <!-- 顶部标签列表 -->
            <TabCtrl class="tab_ctrl" name="tab_ctrl"/>

            <!-- 顶部标签列表后面放一个新建标签按钮 -->
            <Button class="tab_item_new_add_btn" name="btn_add" text="+" tooltip_text_id="STRID_CEF_BROWSER_NEW_TAB"
                    width="24" height="24" border_round="6,6"
                    text_padding="0,0,0,2" margin="2,0,0,0"/>

            <!-- 标题栏区域 -->
            <HBox name="window_title_bar" width="auto" height="36">
                <Control mouse_enabled="false"/>
                <Control width="36" mouse_enabled="false"/>
                <Button class="btn_switch_theme" height="32" width="40" name="btn_window_theme" margin="0,2,0,2"/>
                <Button class="btn_switch_lang" height="32" width="40" name="btn_window_language" margin="0,2,0,2"/>
                <Button class="btn_wnd_fullscreen_11" height="32" width="40" name="btn_window_fullscreen" margin="0,2,0,2"/>
                <Button class="btn_wnd_min_11" height="32" width="40" name="btn_window_min" margin="0,2,0,2"/>
                <Box height="stretch" width="40" margin="0,2,0,2">
                    <Button class="btn_wnd_max_11" height="32" width="stretch" name="btn_window_max"/>
                    <Button class="btn_wnd_restore_11" height="32" width="stretch" name="btn_window_restore" visible="false"/>
                </Box>
                <Button class="btn_wnd_close_11" height="stretch" width="40" name="btn_window_close" margin="0,0,0,2"/>
            </HBox>
        </HBox>
        <!-- 后退/前进/刷新按钮，地址栏，标签栏区域 -->
        <HBox height="30" margin="10,2,10,2" child_margin="3">
            <Button class="btn_cef_browser" name="btn_back" width="60" height="30" border_round="3,3" textid="STRID_CEF_BROWSER_BACKWARD" valign="center" font="system_regular_14" />
            <Button class="btn_cef_browser" name="btn_forward" width="60" height="30" border_round="3,3" textid="STRID_CEF_BROWSER_FORWARD" valign="center" font="system_regular_14" />
            <Box width="60" height="30" valign="center">
                <Button class="btn_cef_browser" name="btn_refresh" width="60" height="30" border_round="3,3" textid="STRID_CEF_BROWSER_REFRESH" valign="center" font="system_regular_14" />
                <Button class="btn_cef_browser" name="btn_stop" width="60" height="30" border_round="3,3" textid="STRID_CEF_BROWSER_STOP" valign="center" font="system_regular_14" />
            </Box>
            <!-- 地址栏 -->
            <RichEdit class="simple simple_border prompt" name="edit_url" width="stretch" height="30" border_round="3,3"
                                            text_padding="5,2,5,0"
                                            text_align="vcenter"
                                            valign="center"
                                            font="system_regular_14"
                                            prompt_textid="STRID_CEF_BROWSER_INPUT_ADDRESS"
                                            default_context_menu="true"
                                            vscrollbar="false"
                                            auto_vscroll="false"
                                            hscrollbar="false"
                                            auto_hscroll="true"/>
        </HBox>

        <!-- 一条分割线 -->
        <Control class="splitline_hor_level1" margin="0,0,0,0" />

        <!-- 网页显示区域：浏览器盒子列表 -->
        <TabBox name="browser_box_tab" bkcolor="white" padding="2,2,2,2"/>
    </VBox>
</Window>