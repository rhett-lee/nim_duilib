<?xml version="1.0" encoding="UTF-8"?>
<Window size="75%,75%" min_size="240,100" 
        caption="0,0,0,36" use_system_caption="false" snap_layout_menu="true" sys_menu="true" sys_menu_rect="0,0,36,36" 
        shadow_type="default" shadow_attached="true" shadow_snap="true" layered_window="true" 
        alpha="255" size_box="4,4,4,4" icon="public/caption/logo.ico">
    <VBox bkcolor="bg_window_dark" visible="true">    
        <!-- 标题栏区域 -->
        <HBox name="window_caption_bar" width="stretch" height="36" bkcolor="bg_titlebar">
            <Control mouse_enabled="false"/>
            <Button class="btn_switch_theme" height="32" width="40" name="btn_switch_theme" margin="0,2,0,2"/>
            <Button class="btn_switch_lang" height="32" width="40" name="btn_switch_lang" margin="0,2,0,2"/>
            <Button class="btn_wnd_fullscreen_11" height="32" width="40" name="fullscreenbtn" margin="0,2,0,2"/>
            <Button class="btn_wnd_min_11" height="32" width="40" name="minbtn" margin="0,2,0,2"/>
            <Box height="stretch" width="40" margin="0,2,0,2">
                <Button class="btn_wnd_max_11" height="32" width="stretch" name="maxbtn"/>
                <Button class="btn_wnd_restore_11" height="32" width="stretch" name="restorebtn" visible="false"/>
            </Box>
            <Button class="btn_wnd_close_11" height="stretch" width="40" name="closebtn" margin="0,0,0,2"/>
        </HBox>
        
        <!-- 工作区域，除了标题栏外的内容都放在这个大的Box区域 -->
        <Box bkcolor="bg_window_light">
            <VBox margin="0,0,0,0" valign="center" halign="center">
                <Label name="tooltip" text_id="STRID_BASIC_TEXT" height="100%" width="100%" text_align="hcenter,vcenter"/>        
            </VBox>
        </Box>
    </VBox>
</Window>