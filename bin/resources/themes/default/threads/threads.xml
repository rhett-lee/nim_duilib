<?xml version="1.0" encoding="UTF-8"?>
<Window size="800,600" min_size="80,60" use_system_caption="false" snap_layout_menu="true" sys_menu="true" sys_menu_rect="0,0,36,36" caption="0,0,0,36" shadow_attached="true" layered_window="true" alpha="255" size_box="4,4,4,4" icon="public/caption/logo.ico">
    <VBox bkcolor="bg_window_dark" visible="true">
        <!-- 标题栏区域 -->
        <HBox name="window_title_bar" width="stretch" height="36" bkcolor="bg_titlebar">
            <Label text_id="STRID_THREADS_TITLE" height="32" text_align="vcenter" margin="10,0,0,0" mouse_enabled="false"/>
            <Control mouse_enabled="false"/>
            <Button class="btn_switch_theme" height="32" width="40" name="btn_window_theme" margin="0,2,0,2"/>
            <Button class="btn_switch_lang" height="32" width="40" name="btn_window_language" margin="0,2,0,2"/>
            <Button class="btn_wnd_fullscreen_11" height="32" width="40" name="btn_window_fullscreen" margin="0,2,0,2"/>
            <Button class="btn_wnd_min_11" height="32" width="40" name="btn_window_min" margin="0,2,0,2"/>
            <Box height="stretch" width="40" margin="0,2,0,2">
                <Button class="btn_wnd_max_11" height="32" width="stretch" name="btn_window_max"/>
                <Button class="btn_wnd_restore_11" height="32" width="stretch" name="btn_window_restore" visible="false"/>
            </Box>
            <Button class="btn_wnd_close_11" height="stretch" width="40" name="btn_window_close" margin="0,0,0,2"/>
        </HBox>

        <!-- 工作区域，除了标题栏外的内容都放在这个大的Box区域 -->
        <VBox padding="6,6,6,6">
            <HBox margin="0,0,0,0" valign="center" halign="center" height="48">
                <Button class="btn_global" width="100" height="30" name="start_threads" text_id="STRID_THREADS_START" margin="2,8,2,2"/>
                <Button class="btn_global" width="100" height="30" name="stop_threads" text_id="STRID_THREADS_STOP" margin="2,8,2,2"/>
                <Label text_id="STRID_THREADS_EXECUTE_IN_THREAD_INFO" height="100%" width="auto" text_align="right,vcenter" margin="8,0,0,0"/>
                <RichEdit class="simple simple_border rich_edit_spin" name="threads_identifier" text="1" valign="center"/>
                <Button class="btn_global" name="run_task_in_threads" width="180" height="30" text_id="STRID_THREADS_EXECUTE_IN_THREAD" margin="8,8,2,2"/>
                <Label text="00:00:00" name="running_time" height="100%" width="100%" text_align="hcenter,vcenter" margin="8,0,0,0"/>
            </HBox>
            <Line height="1" margin="0,0,0,2"/>
            <RichEdit class="simple simple_border" name="log_view" text_align="left,top" width="stretch" height="stretch"
                        hide_selection="true" multi_line="true" vscrollbar="true" auto_vscroll="true" hscrollbar="false"
                        want_return_msg="true" rich_text="false" default_context_menu="true"/>
        </VBox>
    </VBox>
</Window>