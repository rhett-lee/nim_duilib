<?xml version="1.0" encoding="utf-8"?>
<Window shadow_type="menu_round" shadow_attached="true" layered_window="true" shadow_border_size="1" shadow_border_color="border_window">
    <Class name="my_menu_element" height="28" width="160" padding="10,0,10,0" />
    <Class name="my_menu_text" text_align="vcenter,left"/>
    <Class name="my_menu_shortcut" width="100%" text_align="vcenter,right"/>
    <Class name="my_menu_text_hbox" margin="16,0,16,0"/>
    <VListBox class="menu" name="rich_edit_menu" padding="0,4,0,4">
        <!-- 一级菜单 -->
        <MenuItem class="menu_element my_menu_element" name="edit_menu_copy">
            <HBox class="my_menu_text_hbox">
                <Label class="menu_text my_menu_text" text_id="STRID_MENU_TEXT_COPY"/>
                <Label class="menu_text_shortcut my_menu_shortcut" text="Ctrl+C"/>
            </HBox>
        </MenuItem>
        <MenuItem class="menu_element my_menu_element" name="edit_menu_cut">
            <HBox class="my_menu_text_hbox">
                <Label class="menu_text my_menu_text" text_id="STRID_MENU_TEXT_CUT"/>
                <Label class="menu_text_shortcut my_menu_shortcut" text="Ctrl+X"/>
            </HBox>
        </MenuItem>
        <MenuItem class="menu_element my_menu_element" name="edit_menu_paste">
            <HBox class="my_menu_text_hbox">
                <Label class="menu_text my_menu_text" text_id="STRID_MENU_TEXT_PASTE"/>
                <Label class="menu_text_shortcut my_menu_shortcut" text="Ctrl+V"/>
            </HBox>
        </MenuItem>
        <MenuItem class="menu_element my_menu_element" name="edit_menu_del">
            <HBox class="my_menu_text_hbox">
                <Label class="menu_text my_menu_text" text_id="STRID_MENU_TEXT_DEL"/>
                <Label class="menu_text_shortcut my_menu_shortcut" text="Del"/>
            </HBox>
        </MenuItem>

        <!-- 菜单项之间的分割线 -->
        <Box class="menu_split_box">
            <Control class="menu_split_line" />
        </Box>

        <MenuItem class="menu_element my_menu_element" name="edit_menu_sel_all">
            <HBox class="my_menu_text_hbox">
                <Label class="menu_text my_menu_text" text_id="STRID_MENU_TEXT_SEL_ALL"/>
                <Label class="menu_text_shortcut my_menu_shortcut" text="Ctrl+A"/>
            </HBox>
        </MenuItem>

        <MenuItem class="menu_element my_menu_element" name="edit_menu_undo">
            <HBox class="my_menu_text_hbox">
                <Label class="menu_text my_menu_text" text_id="STRID_MENU_TEXT_UNDO"/>
                <Label class="menu_text_shortcut my_menu_shortcut" text="Ctrl+Z"/>
            </HBox>
        </MenuItem>
        <MenuItem class="menu_element my_menu_element" name="edit_menu_redo">
            <HBox class="my_menu_text_hbox">
                <Label class="menu_text my_menu_text" text_id="STRID_MENU_TEXT_REDO"/>
                <Label class="menu_text_shortcut my_menu_shortcut" text="Ctrl+Y"/>
            </HBox>
        </MenuItem>

    </VListBox>
</Window>