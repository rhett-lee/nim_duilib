<?xml version="1.0" encoding="UTF-8"?>
<Window>
    <Class name="color_combo_picker_btn" font="system_regular_14"
                                    normal_text_color="text_default" disabled_text_color="text_disabled"
                                    text_align="hcenter,vcenter" border_size="1"
                                    hot_border_color="border_btn_hover"
                                    pushed_border_color="border_btn_pressed"
                                    hot_color="bg_btn_hover"
                                    pushed_color="bg_btn_pressed" />
    <!-- 第一个节点会被跳过解析 -->
    <Box>
        <VBox bkcolor="bg_window_dark">
            <!-- 常用颜色 -->
            <ColorPickerRegular name="color_combo_picker" color_type="default" item_size="40,20" columns="10" child_margin="2" padding="2,2,2,2" halign="center" valign="center"/>
            <Button class="color_combo_picker_btn" name="color_combo_picker_more" text_id="STRID_PROPERTY_MORE_COLOR" width="auto" height="30" padding="8,0,8,0" margin="2,0,2,2" halign="center"/>
        </VBox>
    </Box>
</Window>
