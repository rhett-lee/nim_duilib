<?xml version="1.0" encoding="UTF-8"?>
<Window>
    <Class name="page_tile_box" margin="10,10,10,10" width="200" height="100" text_padding="4,0,0,0" bkcolor="Sienna" border_size="1" border_color="green"/>
    <HBox width="auto" height="auto">
        <Label text="VTileBox " height="28" valign="center"/>
        <Label text_id="STRID_LAYOUT_TEST_TITLE" height="28" valign="center"/>
        <Label text="（纵向布局）" height="28" valign="center"/>
    </HBox>
    <VTileBox child_halign="left" columns="0" item_size="0,0" scale_down="true" width="stretch" height="auto" padding="10,10,10,10" bkcolor="gray" border_size="1" border_color="red">
        <Control float="true" width="stretch" height="stretch" border_size="1" border_color="green" bkcolor="Cornsilk"/>       
        <Label class="page_tile_box" text="1 left,top" halign="left" valign="top"/>
        <Label class="page_tile_box" text="2 left,center" halign="left" valign="center"/>
        <Label class="page_tile_box" text="3 left,bottom" halign="left" valign="bottom"/>
        <Label class="page_tile_box" text="4 center,top" halign="center" valign="top"/>
        <Label class="page_tile_box" text="5 center,center" halign="center" valign="center"/>
        <Label class="page_tile_box" text="6 center,bottom" halign="center" valign="bottom"/>
        <Label class="page_tile_box" text="7 right,top" halign="right" valign="top"/>
        <Label class="page_tile_box" text="8 right,center" halign="right" valign="center"/>
        <Label class="page_tile_box" text="9 right,bottom" halign="right" valign="bottom"/>
    </VTileBox>

    <HBox width="auto" height="auto">
        <Label text="HTileBox " height="28" valign="center"/>
        <Label text_id="STRID_LAYOUT_TEST_TITLE" height="28" valign="center"/>
        <Label text="（横向布局）" height="28" valign="center"/>
    </HBox>
    <HTileBox child_valign="top" rows="0" item_size="200,0" scale_down="true" width="stretch" height="stretch" padding="10,10,10,10" bkcolor="gray" border_size="1" border_color="red">
        <Control float="true" width="stretch" height="stretch" border_size="1" border_color="green" bkcolor="Cornsilk"/>    
        <Label class="page_tile_box" text="1 left,top" halign="left" valign="top"/>
        <Label class="page_tile_box" text="2 left,center" halign="left" valign="center"/>
        <Label class="page_tile_box" text="3 left,bottom" halign="left" valign="bottom"/>
        <Label class="page_tile_box" text="4 center,top" halign="center" valign="top"/>
        <Label class="page_tile_box" text="5 center,center" halign="center" valign="center"/>
        <Label class="page_tile_box" text="6 center,bottom" halign="center" valign="bottom"/>
        <Label class="page_tile_box" text="7 right,top" halign="right" valign="top"/>
        <Label class="page_tile_box" text="8 right,center" halign="right" valign="center"/>
        <Label class="page_tile_box" text="9 right,bottom" halign="right" valign="bottom"/>
    </HTileBox>
</Window>
