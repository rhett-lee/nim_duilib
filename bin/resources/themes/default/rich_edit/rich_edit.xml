<Window size="90%,80%" size_box="4,4,4,4" use_system_caption="false" snap_layout_menu="true" sys_menu="true" sys_menu_rect="0,0,36,36" caption="0,0,0,36" shadow_attached="true" layered_window="true" text_id="STRID_RICHEDIT_TEST_TITLE">
    <!-- 该窗口下的Class定义 -->
    <Font id="btn_font_bold_14" name="Elephant" size="14" bold="true"/>
    <Font id="btn_font_italic_14" name="Elephant" size="14" bold="true" italic="true"/>
    <Class name="checkbox_font_class" font="system_regular_14" text_align="hcenter,vcenter"
                                      border_size="1"
                                      hot_border_color="border_btn_hover"
                                      pushed_border_color="border_btn_pressed"
                                      selected_normal_color="bg_btn_pressed"
                                      hot_color="border_btn_hover"
                                      selected_hot_color="border_btn_hover"
                                      pushed_color="bg_btn_pressed"
                                      selected_pushed_color="bg_btn_pressed"/>
    <Class name="btn_font_class" font="system_regular_14" text_align="hcenter,vcenter"
                                      border_size="1"
                                      hot_border_color="border_btn_hover"
                                      pushed_border_color="border_btn_pressed"
                                      hot_color="border_btn_hover"
                                      pushed_color="bg_btn_pressed" />

    <!-- 整个窗口中，所有控件都放在这个VBox容器中 -->
    <VBox bkcolor="bg_window_dark">
        <!-- 标题栏区域 -->
        <HBox name="window_title_bar" width="stretch" height="36" bkcolor="bg_titlebar">
            <!-- 标题栏：窗口左上角显示区域 -->
            <HBox margin="0,0,30,0" valign="center" width="auto" height="auto" mouse_enabled="false">
                <Control width="18" height="18" bkimage="public/caption/logo.svg" valign="center" margin="8,0,0,0"/>
                <Label text_id="STRID_RICHEDIT_TEST_TITLE" valign="center" margin="8,0,0,0" mouse_enabled="false"/>
            </HBox>
            <Control mouse_enabled="false"/>
            <!-- 标题栏：右侧窗口控制区域，窗口最小化、最大化、还原、关闭按钮 -->
            <HBox margin="0,0,0,0" valign="center" width="auto" height="36">
                <Button class="btn_switch_theme" height="32" width="40" name="btn_window_theme" margin="0,2,0,2"/>
                <Button class="btn_switch_lang" height="32" width="40" name="btn_window_language" margin="0,2,0,2"/>
                <Button class="btn_wnd_fullscreen_11" height="32" width="40" name="btn_window_fullscreen" margin="0,2,0,2"/>
                <Button class="btn_wnd_min_11" height="32" width="40" name="btn_window_min" margin="0,2,0,2"/>
                <Box height="stretch" width="40" margin="0,2,0,2">
                    <Button class="btn_wnd_max_11" height="32" width="stretch" name="btn_window_max"/>
                    <Button class="btn_wnd_restore_11" height="32" width="stretch" name="btn_window_restore" visible="false"/>
                </Box>
                <Button class="btn_wnd_close_11" height="stretch" width="40" name="btn_window_close" margin="0,0,0,2"/>
            </HBox>
        </HBox>
        <!-- 标题栏区域结束 -->

        <!-- 显示区域 -->
        <HBox>
            <!-- 左侧区域 -->
            <VScrollBox width="360" vscrollbar="true" minwidth="60" bkcolor="bg_window_light" border_size="1,1,1,1" border_color="border_window" border_round="4,4">
                <GroupVBox margin="6,6,6,6" text_id="STRID_RICHEDIT_PASSWORD_FUNC" height="auto" corner_size="4,4">
                    <HBox height="36" margin="8,16,8,0">
                        <Label text_id="STRID_RICHEDIT_PASSWORD_INPUT" valign="center"/>
                        <RichEdit class="simple simple_border" text="This is password!" password="true" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_SHOW_PASSWORD" valign="center"/>
                        <RichEdit class="simple" text="This is password!" password="true" show_password="true" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_FLASH_PASSWORD_CHAR" valign="center"/>
                        <RichEdit class="simple" text="This is password!" password="true" flash_password_char="true" show_password="false" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,8">
                        <Label text_id="STRID_RICHEDIT_PASSWORD_CHAR_HASH" valign="center"/>
                        <RichEdit class="simple" text="This is password!" password="true" password_char="#" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                </GroupVBox>
                <GroupVBox margin="6,6,6,6" text_id="STRID_RICHEDIT_BASIC_FUNC" height="auto" corner_size="4,4">
                    <HBox height="36" margin="8,16,8,0">
                        <Label text_id="STRID_RICHEDIT_SINGLE_LINE_EDIT" valign="center"/>
                        <RichEdit class="simple simple_border" text="RichEdit: simple" default_context_menu="true" valign="center" text_align="vcenter" text_padding="2,0,0,0" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="44" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_SINGLE_LINE_EDIT" valign="center"/>
                        <RichEdit class="simple simple_border" text="RichEdit: edit" valign="center" text_align="vcenter" text_padding="4,4,4,4" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_PROMPT_MODE" valign="center"/>
                        <RichEdit class="prompt simple simple_border_bottom" prompt_text_id="STRID_RICHEDIT_INPUT_TEXT_HERE" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_NUMBER_MODE" valign="center"/>
                        <RichEdit class="simple simple_border" text="0123456789" number="true" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_READONLY_MODE" valign="center"/>
                        <RichEdit class="simple simple_border" text="RichEdit: readonly" readonly="true" no_caret_readonly="true" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_DISABLE_MODE" valign="center"/>
                        <RichEdit class="simple simple_border" enabled="false" text="RichEdit: disabled" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_HYPERLINK" valign="center"/>
                        <RichEdit name="test_url" auto_detect_url="true" text="URL:http://www.baidu.com" readonly="true" no_caret_readonly="true" valign="center" text_align="vcenter" text_padding="2,0,0,0" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_TEXT_COLOR" valign="center"/>
                        <RichEdit class="simple simple_border" text="RichEdit: Red Text" normal_text_color="red" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_CARET_COLOR" valign="center"/>
                        <RichEdit class="simple simple_border" text="RichEdit: Red caret" caret_color="red" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="48" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_TEXT_ALIGN" valign="center"/>
                        <RichEdit class="simple simple_border" text="text_align={left/hcenter/right,top/vcenter/bottom}" text_align="hcenter,vcenter" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,8">
                        <Label text_id="STRID_RICHEDIT_MAX_CHAR_8" valign="center"/>
                        <RichEdit class="simple simple_border" text="Max ch 8" max_char="8" valign="center" text_align="vcenter" margin="4,6,4,4"/>
                    </HBox>
                </GroupVBox>

                <GroupVBox margin="6,6,6,6" text_id="STRID_RICHEDIT_COMMON_FUNC" height="auto" corner_size="4,4">
                    <HBox height="36" margin="8,16,8,0">
                        <Label text_id="STRID_RICHEDIT_SPIN_FUNC" valign="center"/>
                        <RichEdit class="simple simple_border rich_edit_spin" min_number="-64" max_number="64" limit_text="3" margin="4,6,4,4"/>
                        <Label text_id="STRID_RICHEDIT_NUMBER_RANGE_64" valign="center"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_CLEAR_TEXT" valign="center"/>
                        <RichEdit class="simple simple_border rich_edit_clear_btn" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="36" margin="8,0,8,8">
                        <Label text_id="STRID_RICHEDIT_SHOW_PASSWORD" valign="center"/>
                        <RichEdit class="simple simple_border rich_edit_show_password_btn" margin="4,6,4,4"/>
                    </HBox>
                </GroupVBox>

                <GroupVBox margin="6,6,6,6" text_id="STRID_RICHEDIT_SCROLLBAR_FUNC" height="auto" corner_size="4,4">
                    <HBox height="48" margin="8,16,8,0">
                        <Label text_id="STRID_RICHEDIT_HORIZONTAL_SCROLLBAR" valign="center"/>
                        <RichEdit class="simple_border" text="0123456789abcdefghigklmn" multi_line="true" word_wrap="false" hscrollbar="true" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="48" margin="8,0,8,0">
                        <Label text_id="STRID_RICHEDIT_VERTICAL_SCROLLBAR" valign="center"/>
                        <RichEdit class="simple_border" text="0123456789abcdefghigklmn0123456789abcdefghigklmn0123456789abcdefghigklmn0123456789abcdefghigklmn" multi_line="true" want_return="true" word_wrap="true" vscrollbar="true" margin="4,6,4,4"/>
                    </HBox>
                    <HBox height="48" margin="8,0,8,8">
                        <Label text_id="STRID_RICHEDIT_HORIZONTAL_VERTICAL_SCROLLBAR" valign="center"/>
                        <RichEdit class="simple_border" text="0123456789abcdefghigklmn0123456789abcdefghigklmn0123456789abcdefghigklmn0123456789abcdefghigklmn" multi_line="true" want_return="true" word_wrap="false" vscrollbar="true" hscrollbar="true" margin="4,6,4,4"/>
                    </HBox>
                </GroupVBox>

            </VScrollBox>
            <!-- 纵向分割条，用于调整左右区域大小 -->
            <Split class="split_vertical"/>
            <!-- 右侧区域 -->
            <VBox>
                <VBox bkcolor="bg_window_dark" height="auto" minheight="40" >
                    <HBox height="auto" margin="0,2,2,0">
                        <Label text_id="STRID_RICHEDIT_FILE" valign="center" margin="8,0,8,0"/>
                        <Button class="btn_global" name="open_file" width="100" height="28" text_id="STRID_RICHEDIT_OPEN_FILE" borderround="2,2" valign="center" margin="4,0,4,0"/>
                        <Button class="btn_global" name="save_file" width="100" height="28" text_id="STRID_RICHEDIT_SAVE_FILE" borderround="2,2" valign="center" margin="4,0,4,0"/>
                        <Button class="btn_global" name="save_as_file" width="160" height="28" text_id="STRID_RICHEDIT_SAVE_AS_FILE" borderround="2,2" valign="center" margin="4,0,4,0"/>
                    </HBox>
                    <HBox height="auto" margin="0,2,2,0">
                        <Label text_id="STRID_RICHEDIT_EDIT" valign="center" margin="8,0,8,0"/>
                        <Button class="btn_global" name="btn_copy" width="100" height="28" text_id="STRID_RICHEDIT_COPY" borderround="2,2" valign="center" margin="4,0,4,0"/>
                        <Button class="btn_global" name="btn_cut" width="100" height="28" text_id="STRID_RICHEDIT_CUT" borderround="2,2" valign="center" margin="4,0,4,0"/>
                        <Button class="btn_global" name="btn_paste" width="100" height="28" text_id="STRID_RICHEDIT_PASTE" borderround="2,2" valign="center" margin="4,0,4,0"/>
                        <Button class="btn_global" name="btn_delete" width="100" height="28" text_id="STRID_RICHEDIT_DELETE" borderround="2,2" valign="center" margin="4,0,4,0"/>
                        <Button class="btn_global" name="btn_sel_all" width="100" height="28" text_id="STRID_RICHEDIT_SELECT_ALL" borderround="2,2" valign="center" margin="4,0,8,0"/>
                        <Button class="btn_global" name="btn_sel_none" width="100" height="28" text_id="STRID_RICHEDIT_DESELECT" borderround="2,2" valign="center" margin="4,0,8,0"/>
                        <Button class="btn_global" name="btn_undo" width="100" height="28" text_id="STRID_RICHEDIT_UNDO" borderround="2,2" valign="center" margin="4,0,4,0"/>
                        <Button class="btn_global" name="btn_redo" width="100" height="28" text_id="STRID_RICHEDIT_REDO" borderround="2,2" valign="center" margin="4,0,4,0"/>
                    </HBox>
                    <HBox height="auto" margin="0,2,2,0">
                        <Label text_id="STRID_RICHEDIT_FIND" valign="center" margin="8,0,8,0"/>
                        <Button class="btn_global" name="btn_find_text" width="100" height="28" text_id="STRID_RICHEDIT_FIND_TEXT" borderround="2,2" valign="center" margin="4,0,4,0"/>
                        <Button class="btn_global" name="btn_find_next" width="100" height="28" text_id="STRID_RICHEDIT_FIND_NEXT_TEXT" borderround="2,2" valign="center" margin="4,0,4,0"/>
                        <Button class="btn_global" name="btn_replace_text" width="100" height="28" text_id="STRID_RICHEDIT_REPLACE_TEXT" borderround="2,2" valign="center" margin="4,0,4,0"/>
                    </HBox>
                    <HBox height="auto" margin="0,2,2,0">
                        <Label text_id="STRID_RICHEDIT_FONT" valign="center" margin="8,0,8,0"/>
                        <Button class="btn_global" name="set_font" width="100" height="28" text_id="STRID_RICHEDIT_SET_FONT" borderround="2,2" valign="center" margin="4,0,4,2"/>
                        <Combo class="combo" name="combo_font_name" combo_icon_class="" combo_type="drop_down" dropbox_size="0,300" height="28" width="160" tooltip_text_id="STRID_RICHEDIT_SELECT_FONT" margin="2,0,2,2"/>
                        <Combo class="combo" name="combo_font_size" combo_icon_class="" combo_type="drop_down" dropbox_size="0,300" height="28" width="60" margin="2,0,2,0" tooltip_text_id="STRID_RICHEDIT_SELECT_FONT"/>
                        <CheckBox class="checkbox_font_class" name="btn_font_bold" width="28" height="26" text="B" font="btn_font_bold_14" valign="center" margin="2,1,1,3" tooltip_text_id="STRID_RICHEDIT_FONT_BOLD"/>
                        <CheckBox class="checkbox_font_class" name="btn_font_italic" width="28" height="26" text="I" font="btn_font_italic_14" valign="center" margin="1,1,1,3" tooltip_text_id="STRID_RICHEDIT_FONT_ITALIC"/>
                        <CheckBox class="checkbox_font_class" name="btn_font_underline" width="28" height="26" text="U" font="system_underline_14" valign="center" margin="1,1,1,3" tooltip_text_id="STRID_RICHEDIT_FONT_UNDERLINE"/>
                        <CheckBox class="checkbox_font_class" name="btn_font_strikeout" width="28" height="26" text="abc" font="system_strikeout_14" valign="center" margin="1,1,1,3" tooltip_text_id="STRID_RICHEDIT_FONT_STRIKEOUT"/>
                        <Button class="btn_font_class" name="btn_font_size_increase" width="32" height="26" text="A+" font="btn_font_bold_14" valign="center" margin="1,1,1,3" tooltip_text_id="STRID_RICHEDIT_INCREASE_FONT_SIZE"/>
                        <Button class="btn_font_class" name="btn_font_size_decrease" width="32" height="26" text="A-" font="btn_font_bold_14" valign="center" margin="1,1,1,3" tooltip_text_id="STRID_RICHEDIT_DECREASE_FONT_SIZE"/>
                        <ComboButton class="combo_button" name="color_combo_button" height="28" width="48" dropbox_size="240,300" left_button_top_label_text="A" left_button_bottom_label_bkcolor="skyblue"/>
                        <Label text_id="STRID_RICHEDIT_RICH_TEXT_FORMAT_TIPS" font="system_regular_12" valign="center" margin="2,0,2,0" tooltip_text_id="STRID_RICHEDIT_RICH_TEXT_FORMAT_TIPS_DETAIL"/>
                    </HBox>
                    <HBox height="auto" margin="0,2,2,0">
                        <Label text_id="STRID_RICHEDIT_ZOOM" valign="center" margin="8,0,8,0"/>
                        <Label text_id="STRID_RICHEDIT_CURRENT_ZOOM_RATIO" valign="center"/>
                        <Label name="lavel_zoom_value" text_id="STRID_RICHEDIT_ZOOM_100_PERCENT" font="system_bold_14" valign="center" margin="0,0,12,0"/>
                        <Button class="btn_font_class" name="btn_zoom_in" width="64" height="26" text_id="STRID_RICHEDIT_ZOOM_IN" font="system_regular_14" valign="center" margin="1,1,1,3" tooltip_text_id="STRID_RICHEDIT_INCREASE_FONT_SIZE"/>
                        <Button class="btn_font_class" name="btn_zoom_out" width="64" height="26" text_id="STRID_RICHEDIT_ZOOM_OUT" font="system_regular_14" valign="center" margin="1,1,1,3" tooltip_text_id="STRID_RICHEDIT_DECREASE_FONT_SIZE"/>
                        <Button class="btn_font_class" name="btn_zoom_off" width="120" height="26" text_id="STRID_RICHEDIT_RESET_ZOOM" font="system_regular_14" valign="center" margin="1,1,1,3" tooltip_text_id="STRID_RICHEDIT_RESET_FONT_SIZE"/>
                    </HBox>
                    <HBox height="auto" margin="0,2,2,2">
                        <Label text_id="STRID_RICHEDIT_OTHER" valign="center" margin="8,0,8,0"/>
                        <CheckBox class="checkbox_1" name="btn_word_wrap" text_id="STRID_RICHEDIT_AUTO_WRAP" margin="4,0,0,0" selected="true" tooltip_text_id="STRID_RICHEDIT_AUTO_WRAP_TIPS"/>
                        <CheckBox class="checkbox_1" name="btn_rich_text" text_id="STRID_RICHEDIT_RICH_TEXT_MODE" margin="12,0,0,0" selected="true" tooltip_text_id="STRID_RICHEDIT_RICH_TEXT_MODE_TIPS"/>
                        <Label text_id="STRID_RICHEDIT_LINE_SPACING" valign="center" margin="12,0,0,0"/>
                        <Option class="option_1" group="richedit_row_spacing_group" text="1.0" margin="6,0,0,0" text_align="vcenter" selected="true">
                            <Event type="select" receiver="rich_edit" apply_attribute="row_spacing_mul='1.0'" />
                        </Option>
                        <Option class="option_1" group="richedit_row_spacing_group" text="1.15" margin="6,0,0,0" text_align="vcenter">
                            <Event type="select" receiver="rich_edit" apply_attribute="row_spacing_mul='1.15'" />
                        </Option>
                        <Option class="option_1" group="richedit_row_spacing_group" text="1.5" margin="6,0,0,0" text_align="vcenter">
                            <Event type="select" receiver="rich_edit" apply_attribute="row_spacing_mul='1.5'" />
                        </Option>
                        <Option class="option_1" group="richedit_row_spacing_group" text="2.0" margin="6,0,0,0" text_align="vcenter">
                            <Event type="select" receiver="rich_edit" apply_attribute="row_spacing_mul='2.0'" />
                        </Option>
                        <Option class="option_1" group="richedit_row_spacing_group" text="2.5" margin="6,0,0,0" text_align="vcenter">
                            <Event type="select" receiver="rich_edit" apply_attribute="row_spacing_mul='2.5'" />
                        </Option>
                        <Option class="option_1" group="richedit_row_spacing_group" text="3.0" margin="6,0,0,0" text_align="vcenter">
                            <Event type="select" receiver="rich_edit" apply_attribute="row_spacing_mul='3.0'" />
                        </Option>
                        <Label name="row_spacing_tips" text_id="STRID_RICHEDIT_LINE_SPACING_RICH_TEXT_ONLY" valign="center" margin="4,0,0,0"/>
                    </HBox>
                </VBox>
                <!-- 横向分割条，用于调整上下区域大小 -->
                <Split class="split_horizontal"/>
                <HBox bkcolor="Pink" border_size="1" border_color="border_window" border_round="4,4" min_width="60">
                    <RichEdit name="rich_edit" enable_drag_drop="true" zoom="0,0" wheel_zoom="true" multi_line="true" want_return="true" word_wrap="true" rich_text="false" default_context_menu="true" save_selection="true" hide_selection="false" word_wrap="true" vscrollbar="true" auto_vscroll="true" bkcolor="bg_window_light"/>
                </HBox>
            </VBox>
        </HBox>
    </VBox>
</Window>