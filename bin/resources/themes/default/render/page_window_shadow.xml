<?xml version="1.0" encoding="UTF-8"?>
<Window>
    <Class name="page_window_shadow_vbox"     width="180" height="200"/>
    <Class name="page_window_shadow_control"  width="180" height="100%"/>
    <Class name="page_window_shadow_label"    width="100%" height="20" text_align="hcenter" margin="8"/>
    <VBox>
        <HBox width="auto" height="auto">
            <VBox class="page_window_shadow_vbox">
                <Control class="page_window_shadow_control" bkimage="file='public/shadow/shadow_big.svg' width='180' valign='center' halign='center'"/>
                <Label class="page_window_shadow_label" text_id="STRID_RENDER_SHADOW_BIG"/>
            </VBox>
            <VBox class="page_window_shadow_vbox">
                <Control class="page_window_shadow_control" bkimage="file='public/shadow/shadow_big_round.svg' width='180' valign='center' halign='center'"/>
                <Label class="page_window_shadow_label" text_id="STRID_RENDER_SHADOW_BIG_ROUND"/>
            </VBox>
            <VBox class="page_window_shadow_vbox">
                <Control class="page_window_shadow_control" bkimage="file='public/shadow/shadow_small.svg' width='180' valign='center' halign='center'"/>
                <Label class="page_window_shadow_label" text_id="STRID_RENDER_SHADOW_SMALL"/>
            </VBox>
            <VBox class="page_window_shadow_vbox">
                <Control class="page_window_shadow_control" bkimage="file='public/shadow/shadow_small_round.svg' width='180' valign='center' halign='center'"/>
                <Label class="page_window_shadow_label" text_id="STRID_RENDER_SHADOW_SMALL_ROUND"/>
            </VBox>
            <VBox class="page_window_shadow_vbox">
                <Control class="page_window_shadow_control" bkimage="file='public/shadow/shadow_menu.svg' width='180' valign='center' halign='center'"/>
                <Label class="page_window_shadow_label" text_id="STRID_RENDER_SHADOW_MENU"/>
            </VBox>
            <VBox class="page_window_shadow_vbox">
                <Control class="page_window_shadow_control" bkimage="file='public/shadow/shadow_menu_round.svg' width='180' valign='center' halign='center'"/>
                <Label class="page_window_shadow_label" text_id="STRID_RENDER_SHADOW_MENU_ROUND"/>
            </VBox>
        </HBox>
        <VBox>
            <Label text_id="STRID_RENDER_SHADOW_TEST_TITLE" valign="center" margin="12,30,10,0"/>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_TYPE_DEFAULT" selected="true" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_type={default}" />
            </Option>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_TYPE_BIG" selected="false" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_type={big}" />
            </Option>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_TYPE_BIG_ROUND" selected="false" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_type={big_round}" />
            </Option>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_TYPE_SMALL" selected="false" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_type={small}" />
            </Option>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_TYPE_SMALL_ROUND" selected="false" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_type={small_round}" />
            </Option>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_TYPE_MENU" selected="false" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_type={menu}" />
            </Option>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_TYPE_MENU_ROUND" selected="false" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_type={menu_round}" />
            </Option>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_TYPE_NONE" selected="false" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_type={none}" />
            </Option>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_TYPE_NONE_ROUND" selected="false" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_type={none_round}" />
            </Option>
            <Option class="checkbox_2" group="shadow_type" text_id="STRID_RENDER_SHADOW_CLOSE_FUNC" selected="false" valign="center" margin="30,4,0,2">
                <Event type="select" receiver="#window#" apply_attribute="shadow_attached={false}" />
            </Option>
        </VBox>
    </VBox>
</Window>