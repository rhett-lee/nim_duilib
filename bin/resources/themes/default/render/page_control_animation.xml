<?xml version="1.0" encoding="UTF-8"?>
<Box>
    <VBox bkcolor="white">
        <HBox child_margin_x="8">
            <VBox bkcolor="white" height="auto" border_size="1" width="300" height="200" border_color="gray" padding="2,2,2,2">
                <Button class="btn_global_color_gray" width="180" height="32" border_round="3,3" halign="center" valign='center'
                        text="鼠标划入显示下面的控件" tooltip_text="fade_alpha='true'">
                    <Event type="mouse_enter" receiver="fade_alpha_1" apply_attribute="fade_visible='true'" />
                    <Event type="mouse_leave" receiver="fade_alpha_1" apply_attribute="fade_visible='false'" />
                </Button>
                <Control name="fade_alpha_1" halign="center" margin="30,30,30,30" width="160" height="100" bkcolor="red" border_round="4,4" visible="false" fade_alpha="true"/>
            </VBox>
            <VBox bkcolor="white" height="auto" border_size="1" width="300" height="200" border_color="gray" padding="2,2,2,2">
                <Button class="btn_global_color_gray" width="180" height="32" border_round="3,3" halign="center" valign='center'
                        text="鼠标划入显示下面的控件" tooltip_text="fade_alpha='true'">
                    <Event type="mouse_enter" receiver="fade_alpha_2" apply_attribute="fade_visible='true'" />
                    <Event type="mouse_leave" receiver="fade_alpha_2" apply_attribute="fade_visible='false'" />
                </Button>
                <Control name="fade_alpha_2"  halign="center" margin="30,30,30,30" width="160" height="100" bkcolor="red" border_round="4,4" border_size="2" border_color="blue" visible="false" fade_alpha="true"/>
            </VBox>
            <VBox bkcolor="white" height="auto" border_size="1" width="300" height="200" border_color="gray" padding="2,2,2,2">
                <Button class="btn_global_color_gray" width="180" height="32" border_round="3,3" halign="center" valign='center'
                        text="鼠标划入显示下面的控件" tooltip_text="fade_alpha='true'">
                    <Event type="mouse_enter" receiver="fade_alpha_3" apply_attribute="fade_visible='true'" />
                    <Event type="mouse_leave" receiver="fade_alpha_3" apply_attribute="fade_visible='false'" />
                </Button>
                <Control name="fade_alpha_3" halign="center" margin="30,30,30,30" width="160" height="100" bkcolor="red" border_round="4,4" box_shadow="color='gray' offset='1,1' blur_radius='3' spread_radius='3'" visible="false" fade_alpha="true"/>
            </VBox>
            <VBox margin="4,0,0,0" bkcolor="white" height="auto" border_size="1" width="200" height="200" border_color="gray" padding="2,2,2,2">
                <Label halign="center" text="控件的Hot状态动画" tooltip_text="fade_hot='true'"/>
                <VBox child_margin_y="8" padding="50,10,10,10">
                    <Button class="btn_global_blue_80x30" text="blue"/>
                    <Button class="btn_global_red_80x30" text="red"/>
                    <Button class="btn_global_white_80x30" text="white"/>
                    <Button class="btn_global_gray_80x30" text="gray"/>
                </VBox>
            </VBox>
        </HBox>
        <HBox child_margin_x="8">
            <VBox bkcolor="white" height="auto" border_size="1" width="300" height="200" border_color="gray" padding="2,2,2,2">
                <Button class="btn_global_color_gray" width="260" height="32" border_round="3,3" halign="center" valign='center'
                        text="鼠标划入显示下面的控件(左侧滑入)" tooltip_text="fade_in_out_x_from_left='true'">
                    <Event type="mouse_enter" receiver="fade_in_out_x_from_left_1" apply_attribute="fade_visible='true'" />
                    <Event type="mouse_leave" receiver="fade_in_out_x_from_left_1" apply_attribute="fade_visible='false'" />
                </Button>
                <Control name="fade_in_out_x_from_left_1" halign="center" margin="30,30,30,30" width="160" height="100" bkcolor="red" border_round="4,4" visible="false" fade_in_out_x_from_left="true"/>
            </VBox>
            <VBox bkcolor="white" height="auto" border_size="1" width="300" height="200" border_color="gray" padding="2,2,2,2">
                <Button class="btn_global_color_gray" width="260" height="32" border_round="3,3" halign="center" valign='center'
                        text="鼠标划入显示下面的控件(右侧滑入)" tooltip_text="fade_in_out_x_from_right='true'">
                    <Event type="mouse_enter" receiver="fade_in_out_x_from_right_1" apply_attribute="fade_visible='true'" />
                    <Event type="mouse_leave" receiver="fade_in_out_x_from_right_1" apply_attribute="fade_visible='false'" />
                </Button>
                <Control name="fade_in_out_x_from_right_1" halign="center" margin="30,30,30,30" width="160" height="100" bkcolor="red" border_round="4,4" visible="false" fade_in_out_x_from_right="true"/>
            </VBox>
            <VBox bkcolor="white" height="auto" border_size="1" width="300" height="200" border_color="gray" padding="2,2,2,2">
                <Button class="btn_global_color_gray" width="260" height="32" border_round="3,3" halign="center" valign='center'
                        text="鼠标划入显示下面的控件(上方滑入)" tooltip_text="fade_in_out_y_from_top='true'">
                    <Event type="mouse_enter" receiver="fade_in_out_y_from_top_1" apply_attribute="fade_visible='true'" />
                    <Event type="mouse_leave" receiver="fade_in_out_y_from_top_1" apply_attribute="fade_visible='false'" />
                </Button>
                <Control name="fade_in_out_y_from_top_1" halign="center" margin="30,30,30,30" width="160" height="100" bkcolor="red" border_round="4,4" visible="false" fade_in_out_y_from_top="true"/>
            </VBox>
            <VBox bkcolor="white" height="auto" border_size="1" width="300" height="200" border_color="gray" padding="2,2,2,2">
                <Button class="btn_global_color_gray" width="260" height="32" border_round="3,3" halign="center" valign='center'
                        text="鼠标划入显示下面的控件(底部滑入)" tooltip_text="fade_in_out_y_from_bottom='true'">
                    <Event type="mouse_enter" receiver="fade_in_out_y_from_bottom_1" apply_attribute="fade_visible='true'" />
                    <Event type="mouse_leave" receiver="fade_in_out_y_from_bottom_1" apply_attribute="fade_visible='false'" />
                </Button>
                <Control name="fade_in_out_y_from_bottom_1" halign="center" margin="30,30,30,30" width="160" height="100" bkcolor="red" border_round="4,4" visible="false" fade_in_out_y_from_bottom="true"/>
            </VBox>
        </HBox>
    </VBox>
</Box>
