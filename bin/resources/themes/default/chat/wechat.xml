<?xml version="1.0" encoding="UTF-8"?>
<Window size="1024,768" caption="0,0,0,35" use_system_caption="false" shadow_attached="true" layered_window="true">
    <HBox>
        <!-- 左侧菜单栏 -->
        <VBox width="60" bkcolor="darkcolor">
            <Control bkimage="head.png" width="40" height="40" margin="10,10"/>
        </VBox>
        <!-- 好友列表 -->
        <VBox width="270" bkcolor="light_gray">
            <Box padding="10,8,10,8" height="auto">
                <RichEdit class="simple simple_border prompt" name="nickname" width="stretch" height="35" font="system_regular_14" text_align="vcenter" text_padding="25,8,8,8" border_round="5,5" prompt_text="Search"/>
                <Control width="auto" height="auto" margin="6,9" bkimage="search_icon.png"/>
            </Box>
            <VBox>
                <!-- Firends -->
            </VBox>
        </VBox>
        <!-- 聊天区域 -->
        <VBox>
            <HBox height="80" bkcolor="bg_window_dark">
            </HBox>
            <Control class="splitline_hor_level1"/>
            <VBox bkcolor="bg_window_dark">
            </VBox>
            <VBox height="150" bkcolor="bg_window_light">
            </VBox>
        </VBox>
    </HBox>
</Window>