<?xml version="1.0" encoding="UTF-8"?>
<Window size="85%,85%" min_size="80,50" use_system_caption="false" caption="0,0,0,36" shadow_attached="true" layered_window="true" size_box="4,4,4,4">
    <!-- 整个窗口中，所有控件都放在这个VBox容器中 -->
    <VBox bkcolor="bg_window_dark">
        <!-- 标题栏区域 -->
        <HBox name="window_title_bar" width="stretch" height="36" bkcolor="bg_titlebar">
            <!-- 标题栏：窗口左上角显示区域 -->
            <HBox margin="0,0,30,0" valign="center" width="auto" height="auto" mouse_enabled="false">
                <Label text_id="STRID_LISTCTRL_TEST_TITLE" valign="center" margin="8,0,0,0" mouse_enabled="false"/>
            </HBox>
            <Control mouse_enabled="false"/>
            <!-- 标题栏：右侧窗口控制区域，窗口最小化、最大化、还原、关闭按钮 -->
            <HBox margin="0,0,0,0" valign="center" width="auto" height="36">
                <Button class="btn_switch_theme" height="32" width="40" name="btn_window_theme" margin="0,2,0,2"/>
                <Button class="btn_switch_lang" height="32" width="40" name="btn_window_language" margin="0,2,0,2"/>
                <Button class="btn_wnd_fullscreen_11" height="32" width="40" name="btn_window_fullscreen" margin="0,2,0,2"/>
                <Button class="btn_wnd_min_11" height="32" width="40" name="btn_window_min" margin="0,2,0,2"/>
                <Box height="stretch" width="40" margin="0,2,0,2">
                    <Button class="btn_wnd_max_11" height="32" width="stretch" name="btn_window_max"/>
                    <Button class="btn_wnd_restore_11" height="32" width="stretch" name="btn_window_restore" visible="false"/>
                </Box>
                <Button class="btn_wnd_close_11" height="stretch" width="40" name="btn_window_close" margin="0,0,0,2"/>
            </HBox>
        </HBox>
        <!-- 标题栏区域结束 -->


        <!-- 工作区域，除了标题栏外的内容都放在这个大的Box区域 -->
        <VBox bkcolor="bg_window_light" >
            <HBox height="auto">
                <Label text_id="STRID_LISTCTRL_TABLE_TYPE" valign="center" margin="2,0,2,0"/>
                <Combo class="combo" name="list_ctrl_type_combo" combo_type="drop_list" dropbox_size="0,300" combo_icon_class="" height="26" width="80" margin="0,0,0,1" valign="center">
                    <TreeNode class="tree_node" padding="4" text_id="STRID_LISTCTRL_REPORT" user_dataid="0"/>
                    <TreeNode class="tree_node" padding="4" text_id="STRID_LISTCTRL_ICON" user_dataid="1"/>
                    <TreeNode class="tree_node" padding="4" text_id="STRID_LISTCTRL_LIST" user_dataid="2"/>
                </Combo>
                <CheckBox class="checkbox_1" name="checkbox_multi_select" text_id="STRID_LISTCTRL_SUPPORT_MULTI_SELECT" margin="4,0,0,0" valign="center">
                    <Event type="select" receiver="list_ctrl" applyattribute="multi_select={true}" />
                    <Event type="unselect" receiver="list_ctrl" applyattribute="multi_select={false}" />
                </CheckBox>
            </HBox>
            <HBox height="auto">
                <GroupVBox class="group_box_round" name="report_group" height="auto" width="820" margin="2,0,0,0" text_id="STRID_LISTCTRL_REPORT_TYPE">
                    <HBox minheight="18" height="auto" margin="4,18,4,0">
                        <Label text_id="STRID_LISTCTRL_HEADER_CONTROL" valign="center" margin="2,0,2,0"/>
                        <Option class="option_2" group="show" selected="false" width="64" height="32" text_id="STRID_LISTCTRL_HIDE" padding="2,2,2,2" borderround="2,2" valign="center">
                            <Event type="select" receiver="list_ctrl" applyattribute="show_header={false}" />
                        </Option>
                        <Option class="option_2" group="show" selected="true" width="64" height="32" text_id="STRID_LISTCTRL_SHOW" padding="2,2,2,2" borderround="2,2" valign="center">
                            <Event type="select" receiver="list_ctrl" applyattribute="show_header={true}" />
                        </Option>
                        <Line vertical="true" margin="0,8,4,8" width="2"/>
                        <Label text_id="STRID_LISTCTRL_DRAG_HEADER_REORDER" valign="center" margin="2,0,2,0"/>
                        <Option class="option_2" group="drag_order" selected="false" width="64" height="32" text_id="STRID_LISTCTRL_DISABLE" padding="2,2,2,2" borderround="2,2" valign="center">
                            <Event type="select" receiver="list_ctrl" applyattribute="enable_header_drag_order={false}" />
                        </Option>
                        <Option class="option_2" group="drag_order" selected="true" width="64" height="32" text_id="STRID_LISTCTRL_ENABLE" padding="2,2,2,2" borderround="2,2" valign="center">
                            <Event type="select" receiver="list_ctrl" applyattribute="enable_header_drag_order={true}" />
                        </Option>
                        <Line vertical="true" margin="0,8,4,8" width="2"/>
                        <Label text_id="STRID_LISTCTRL_HEADER_HEIGHT" valign="center" margin="2,0,2,0"/>
                        <RichEdit class="simple simple_border rich_edit_spin" name="header_height_edit" min_number="0" max_number="512" limit_text="3" text="0" margin="0,2,0,0"/>
                        <Button class="btn_primary_global" name="set_column_stretch" text_id="STRID_LISTCTRL_SET_COLUMN_WIDTH_BY_RATIO" width="auto" height="30" border_round="3,3" text_padding="8,0,8,0" margin="4,0,0,0"/>
                    </HBox>

                    <HBox minheight="18" height="auto" margin="4,0,4,0">
                        <Label text_id="STRID_LISTCTRL_COLUMN_CONTROL" valign="center" margin="2,0,2,0"/>
                        <Combo class="combo" name="column_combo" combo_type="drop_list" dropbox_size="0,300" combo_icon_class="" height="26" width="80" margin="0,0,0,1" valign="center"/>
                        <Line vertical="true" margin="8,4,4,4" width="2"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_show" text_id="STRID_LISTCTRL_SHOW_THIS_COLUMN" margin="4,0,0,0" valign="center"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_width" text_id="STRID_LISTCTRL_RESIZABLE_COLUMN_WIDTH" margin="4,0,0,0" valign="center"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_sort" text_id="STRID_LISTCTRL_SORTABLE" margin="4,0,0,0" valign="center"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_icon_at_top" text_id="STRID_LISTCTRL_SORT_ICON_AT_TOP" margin="4,0,0,0" valign="center"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_drag_order" text_id="STRID_LISTCTRL_DRAG_REORDERABLE" margin="4,0,0,0" valign="center"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_editable" text_id="STRID_LISTCTRL_EDITABLE_TEXT" margin="4,0,0,0" valign="center"/>
                    </HBox>
                    <HBox minheight="18" height="auto" margin="4,0,4,0">
                        <Control width="153"/>
                        <Line vertical="true" margin="8,2,4,2" width="2"/>
                        <Label text_id="STRID_LISTCTRL_COLUMN_LEVEL_CHECKBOX" valign="center" margin="2,0,2,0" tooltip_text_id="STRID_LISTCTRL_COLUMN_LEVEL_CHECKBOX_TIPS"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_show_header_checkbox" text_id="STRID_LISTCTRL_SHOW_IN_HEADER" margin="4,0,0,0" valign="center"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_show_checkbox" text_id="STRID_LISTCTRL_SHOW_IN_EACH_COLUMN" margin="4,0,0,0" valign="center"/>
                        <Line vertical="true" margin="8,2,4,2" width="2"/>
                        <Label text_id="STRID_LISTCTRL_COLUMN_LEVEL_ICON" valign="center" margin="2,0,2,0" tooltip_text_id="STRID_LISTCTRL_COLUMN_LEVEL_ICON_TIPS"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_show_header_icon" text_id="STRID_LISTCTRL_SHOW_IN_HEADER" margin="4,0,0,0" valign="center"/>
                        <CheckBox class="checkbox_1" name="checkbox_column_show_icon" text_id="STRID_LISTCTRL_SHOW_IN_EACH_COLUMN" margin="4,0,0,0" valign="center"/>
                    </HBox>
                    <HBox minheight="18" height="auto" margin="4,0,4,0">
                        <Control width="153"/>
                        <Line vertical="true" margin="8,8,4,8" width="2"/>
                        <Label text_id="STRID_LISTCTRL_HEADER_TEXT" valign="center" margin="6,0,2,0"/>
                        <Option class="option_2" name="header_text_align_left" group="header_text_align" selected="false" width="64" height="32" text_id="STRID_LISTCTRL_ALIGN_LEFT" padding="2,2,2,2" borderround="2,2" valign="center"/>
                        <Option class="option_2" name="header_text_align_center" group="header_text_align" selected="true" width="64" height="32" text_id="STRID_LISTCTRL_ALIGN_CENTER" padding="2,2,2,2" borderround="2,2" valign="center"/>
                        <Option class="option_2" name="header_text_align_right" group="header_text_align" selected="false" width="64" height="32" text_id="STRID_LISTCTRL_ALIGN_RIGHT" padding="2,2,2,2" borderround="2,2" valign="center"/>
                        <Line vertical="true" margin="8,8,4,8" width="2"/>
                        <Label text_id="STRID_LISTCTRL_TABLE_TEXT" valign="center" margin="6,0,2,0"/>
                        <Option class="option_2" name="column_text_align_left" group="column_text_align" selected="true" width="64" height="32" text_id="STRID_LISTCTRL_ALIGN_LEFT" padding="2,2,2,2" borderround="2,2" valign="center"/>
                        <Option class="option_2" name="column_text_align_center" group="column_text_align" selected="false" width="64" height="32" text_id="STRID_LISTCTRL_ALIGN_CENTER" padding="2,2,2,2" borderround="2,2" valign="center"/>
                        <Option class="option_2" name="column_text_align_right" group="column_text_align" selected="false" width="64" height="32" text_id="STRID_LISTCTRL_ALIGN_RIGHT" padding="2,2,2,2" borderround="2,2" valign="center"/>
                    </HBox>

                    <HBox minheight="18" height="auto" margin="4,0,4,0">
                        <Label text_id="STRID_LISTCTRL_TABLE_PROPERTIES" valign="center" margin="2,0,2,0"/>
                        <Label text_id="STRID_LISTCTRL_HORIZONTAL_GRID" valign="center" margin="2,0,2,0"/>
                        <Option class="option_2" group="grid_line_row" selected="false" width="64" height="32" text_id="STRID_LISTCTRL_HIDE" padding="2,2,2,2" borderround="2,2" valign="center">
                            <Event type="select" receiver="list_ctrl" applyattribute="row_grid_line_width={0}" />
                        </Option>
                        <Option class="option_2" group="grid_line_row" selected="true" width="64" height="32" text_id="STRID_LISTCTRL_SHOW" padding="2,2,2,2" borderround="2,2" valign="center">
                            <Event type="select" receiver="list_ctrl" applyattribute="row_grid_line_width={1}" />
                        </Option>
                        <Line vertical="true" margin="0,8,4,8" width="2"/>
                        <Label text_id="STRID_LISTCTRL_VERTICAL_GRID" valign="center" margin="2,0,2,0"/>
                        <Option class="option_2" group="grid_line_column" selected="false" width="64" height="32" text_id="STRID_LISTCTRL_HIDE" padding="2,2,2,2" borderround="2,2" valign="center">
                            <Event type="select" receiver="list_ctrl" applyattribute="column_grid_line_width={0}" />
                        </Option>
                        <Option class="option_2" group="grid_line_column" selected="true" width="64" height="32" text_id="STRID_LISTCTRL_SHOW" padding="2,2,2,2" borderround="2,2" valign="center">
                            <Event type="select" receiver="list_ctrl" applyattribute="column_grid_line_width={1}" />
                        </Option>
                        <Line vertical="true" margin="0,8,4,8" width="2"/>
                        <Label text_id="STRID_LISTCTRL_ROW_HEIGHT" valign="center" margin="2,0,2,0"/>
                        <RichEdit class="simple simple_border rich_edit_spin" name="list_item_height_edit" min_number="0" max_number="512" limit_text="3" text="0" margin="0,2,0,0"/>
                    </HBox>
                    <HBox minheight="18" height="auto" margin="4,0,4,8">
                        <Control width="153"/>
                        <Line vertical="true" margin="8,2,4,2" width="2"/>
                        <Label text_id="STRID_LISTCTRL_ROW_LEVEL_CHECKBOX" valign="center" margin="2,0,2,0" tooltip_text_id="STRID_LISTCTRL_ROW_LEVEL_CHECKBOX_TIPS"/>
                        <CheckBox class="checkbox_1" name="checkbox_show_header_checkbox" text_id="STRID_LISTCTRL_SHOW_IN_HEADER" margin="4,0,0,0" valign="center"/>
                        <CheckBox class="checkbox_1" name="checkbox_show_checkbox" text_id="STRID_LISTCTRL_SHOW_AT_ROW_START" margin="4,0,0,0" valign="center"/>
                        <Line vertical="true" margin="8,2,4,2" width="2"/>
                        <Label text_id="STRID_LISTCTRL_ROW_LEVEL_ICON" valign="center" margin="2,0,2,0" tooltip_text_id="STRID_LISTCTRL_ROW_LEVEL_ICON_TIPS"/>
                        <CheckBox class="checkbox_1" name="checkbox_show_icon" text_id="STRID_LISTCTRL_SHOW_AT_ROW_START" margin="4,0,0,0" valign="center"/>
                    </HBox>
                </GroupVBox>
                <HBox>
                    <GroupVBox class="group_box_round" text_id="STRID_LISTCTRL_OTHER_TESTS" margin="2,0,2,0">
                        <Button class="btn_global" name="loading_progress_btn1" text_id="STRID_LISTCTRL_LOADING_TEST_PROGRESS1" width="200" height="30" border_round="3,3" margin="20,25,10,0"/>
                        <Button class="btn_global" name="loading_progress_btn2" text_id="STRID_LISTCTRL_LOADING_TEST_PROGRESS2" width="200" height="30" border_round="3,3" margin="20,4,10,0"/>
                        <Button class="btn_global" name="loading_btn1" text_id="STRID_LISTCTRL_LOADING_TEST1" width="200" height="30" border_round="3,3" margin="20,4,10,0"/>
                        <Button class="btn_global" name="loading_btn2" text_id="STRID_LISTCTRL_LOADING_TEST2" width="200" height="30" border_round="3,3" margin="20,4,10,0"/>
                    </GroupVBox>
                    <GroupVBox class="group_box_round" text_id="STRID_LISTCTRL_OTHER_TESTS" margin="0,0,2,0">
                        <Button class="btn_global" name="loading_btn3" text_id="STRID_LISTCTRL_LOADING_TEST3" width="200" height="30" border_round="3,3" margin="20,25,10,0"/>
                        <Button class="btn_global" name="loading_btn4" text_id="STRID_LISTCTRL_LOADING_TEST4" width="200" height="30" border_round="3,3" margin="20,4,10,0"/>
                        <Button class="btn_global" name="loading_btn5" text_id="STRID_LISTCTRL_LOADING_TEST5" width="200" height="30" border_round="3,3" margin="20,4,10,0"/>
                        <Button class="btn_global" name="loading_btn6" text_id="STRID_LISTCTRL_LOADING_TEST6" width="200" height="30" border_round="3,3" margin="20,4,10,0"/>
                    </GroupVBox>
                </HBox>
            </HBox>
            <!-- 横向分割条，用于调整上下区域大小 -->
            <Split class="split_horizontal"/>
            <VBox valign="center" halign="center">
                <ListCtrl class="list_ctrl" name="list_ctrl" bkcolor="YellowGreen"
                          loading="file='loading_progress1.xml' width='0' height='0' offset_x='-1' offset_y='-1' valign='center' halign='center' fade='255' animation_control='loading_animation' auto_stop='true'"/>
            </VBox>
        </VBox>
    </VBox>
</Window>